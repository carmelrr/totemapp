// Storage Security Rules - Production Ready
// חוקי אבטחה לאחסון קבצים

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // ==================== Helper Functions ====================
    
    // בדיקה שהמשתמש מחובר
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // בדיקה שזה המשתמש עצמו
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // בדיקת admin עם Custom Claims
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }
    
    // בדיקה שהקובץ הוא תמונה
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }
    
    // בדיקה שהתמונה מסוג מותר
    function isAllowedImageType() {
      return request.resource.contentType in ['image/jpeg', 'image/png', 'image/webp', 'image/gif'];
    }
    
    // בדיקת גודל קובץ מקסימלי (בבייטים)
    function isUnderMaxSize(maxSizeBytes) {
      return request.resource.size < maxSizeBytes;
    }
    
    // ==================== User Profile Images ====================
    // תמונות פרופיל - רק המשתמש יכול לעדכן את שלו
    match /users/{userId}/profile/{fileName} {
      // כולם יכולים לקרוא תמונות פרופיל
      allow read: if true;
      
      // רק המשתמש עצמו יכול להעלות/למחוק תמונת פרופיל שלו
      allow write: if isOwner(userId) && 
        isImage() && 
        isAllowedImageType() && 
        isUnderMaxSize(5 * 1024 * 1024); // 5MB max
    }
    
    // ==================== Community Routes Images ====================
    // תמונות מסלולי קהילה
    match /community-routes/{userId}/{fileName} {
      // כולם יכולים לקרוא
      allow read: if true;
      
      // רק המשתמש עצמו יכול להעלות לתיקייה שלו
      allow create, update: if isOwner(userId) && 
        isImage() && 
        isAllowedImageType() && 
        isUnderMaxSize(10 * 1024 * 1024); // 10MB max
      
      // רק המשתמש עצמו יכול למחוק מהתיקייה שלו
      allow delete: if isOwner(userId);
    }
    
    // ==================== Route Images ====================
    // תמונות מסלולים כלליות
    match /routes/{routeId}/{fileName} {
      // כולם יכולים לקרוא
      allow read: if true;
      
      // רק משתמשים מחוברים יכולים להעלות
      allow create, update: if isAuthenticated() && 
        isImage() && 
        isAllowedImageType() && 
        isUnderMaxSize(10 * 1024 * 1024); // 10MB max
      
      // מחיקה: רק מנהלים (לא ניתן לבדוק ownership ב-Storage rules ללא metadata)
      allow delete: if isAdmin();
    }
    
    // ==================== Competition Images ====================
    // תמונות תחרויות (רק מנהלים)
    match /competitions/{competitionId}/{fileName} {
      allow read: if true;
      // העלאה רק דרך Admin SDK (מנהלים) - לא דרך הקליינט
      allow write: if false;
    }
    
    // ==================== Spray Wall Images ====================
    // תמונות קירות ספריי - מנהלים יכולים להעלות, כולם יכולים לקרוא
    match /sprayWalls/{wallPath=**} {
      allow read: if true;
      // רק משתמשים מחוברים יכולים להעלות (הגבלה נוספת מצד הקוד)
      allow create, update: if isAuthenticated() && 
        isImage() && 
        isAllowedImageType() && 
        isUnderMaxSize(15 * 1024 * 1024); // 15MB max for wall images
      
      // מחיקה: רק מנהלים
      allow delete: if isAdmin();
    }

    // ==================== Announcement Images ====================
    // תמונות הודעות - רק מנהלים יכולים להעלות/למחוק
    match /announcements/images/{fileName} {
      // כולם יכולים לקרוא תמונות הודעות
      allow read: if true;
      
      // רק מנהלים יכולים להעלות/למחוק תמונות הודעות
      allow create, update: if isAdmin() && 
        isImage() && 
        isAllowedImageType() && 
        isUnderMaxSize(10 * 1024 * 1024); // 10MB max
      
      // רק מנהלים יכולים למחוק
      allow delete: if isAdmin();
    }

    // ==================== Q&A Media (knowledge base) ====================
    // מדיה לשאלות ותשובות — תמונות ווידאו. ההצמדה בפועל למאגר נשלטת ע"י כללי Firestore
    // (questions/qaFolders — מנהל/אדמין בלבד), כך שמספיק כאן אימות משתמש.
    match /qa/{allPaths=**} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() &&
        (request.resource.contentType.matches('image/.*') || request.resource.contentType.matches('video/.*')) &&
        request.resource.size < 100 * 1024 * 1024; // 100MB cap (video)
      allow delete: if isAuthenticated();
    }

    // ==================== Default Deny ====================
    // כל מה שלא מוגדר במפורש - אסור!
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}