{
  "expo": {
    "name": "TOTEM",
    "slug": "climbing-gym-app",
    "scheme": "totem-app",
    "version": "1.1.4",
    "orientation": "default",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "automatic",
    "jsEngine": "hermes",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0B0F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "totemapp.com",
      "buildNumber": "9",
      "googleServicesFile": "./GoogleService-Info.plist",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to upload climbing wall images",
        "NSCameraUsageDescription": "This app needs camera access to take photos of climbing routes",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#0B0B0F"
      },
      "versionCode": 10,
      "package": "com.totemapp.climbing",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "totem-app",
              "host": "auth"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "This app needs access to your photo library to upload climbing wall images",
          "cameraPermission": "This app needs camera access to take photos of climbing routes"
        }
      ],
      "expo-font",
      "expo-asset",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/icon.png",
          "color": "#FF6B35",
          "sounds": []
        }
      ],
      "expo-web-browser",
      "@react-native-google-signin/google-signin",
      "expo-apple-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "314d40f3-b56b-4919-9dfe-817d3f8a0540"
      }
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/314d40f3-b56b-4919-9dfe-817d3f8a0540"
    }
  }
}
