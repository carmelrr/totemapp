// Firestore Security Rules - Production Ready
// חוקי אבטחה לייצור עם הגנה מלאה על מידע משתמשים
// Updated: 2026-01-24

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==================== Helper Functions ====================
    
    // בדיקה שהמשתמש מחובר
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // בדיקה שזה המשתמש עצמו
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // בדיקה שהמשתמש הוא מנהל - מעדיף Custom Claims (מאובטח יותר)
    function isAdminByClaim() {
      return isAuthenticated() && request.auth.token.admin == true;
    }
    
    function isAdmin() {
      return isAdminByClaim() || 
        (isAuthenticated() && 
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }

    // בדיקה שהמשתמש הוא מנהל משמרת
    function isShiftManager() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/userShiftRoles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/userShiftRoles/$(request.auth.uid)).data.isShiftManager == true;
    }

    // בדיקה שהמשתמש הוא עובד (צוות) — יש לו רשומת userShiftRoles פעילה.
    // משמש לגידור משימות / שאלות-ותשובות לצוות בלבד (לא לכל מטפס).
    function isWorker() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/userShiftRoles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/userShiftRoles/$(request.auth.uid)).data.isActive == true;
    }
    
    // בדיקה אם השופט קיים בתחרות
    function isJudge(competitionId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/competitions/$(competitionId)/judges/$(request.auth.uid));
    }
    
    // קבלת הרשאות שופט
    function getJudgePermissions(competitionId) {
      return get(/databases/$(database)/documents/competitions/$(competitionId)/judges/$(request.auth.uid)).data.permissions;
    }
    
    function canJudgeEnterResults(competitionId) {
      return isJudge(competitionId) && getJudgePermissions(competitionId).canEnterResults == true;
    }
    
    function canJudgeEditResults(competitionId) {
      return isJudge(competitionId) && getJudgePermissions(competitionId).canEditResults == true;
    }
    
    function canJudgeAddParticipants(competitionId) {
      return isJudge(competitionId) && getJudgePermissions(competitionId).canAddParticipants == true;
    }
    
    function isCompetitionActive(competitionId) {
      return get(/databases/$(database)/documents/competitions/$(competitionId)).data.status == 'active';
    }
    
    // ולידציה בסיסית לכתיבת תוצאות תחרות.
    // Basic validation for competition result writes: aggregate scores must be
    // non-negative numbers. Per-route attempt limits are enforced in the app
    // (Firestore rules cannot iterate over the routes map).
    function validCompetitionResult() {
      let d = request.resource.data;
      return d.totalPoints is number && d.totalPoints >= 0
        && (!('top7Points' in d) || (d.top7Points is number && d.top7Points >= 0))
        && (!('routesCompleted' in d) || (d.routesCompleted is number && d.routesCompleted >= 0))
        && (!('totalAttempts' in d) || (d.totalAttempts is number && d.totalAttempts >= 0));
    }
    
    // בדיקת גודל מסמך - מניעת התקפות מילוי
    // Note: request.resource.size is not always reliable, so we keep it simple
    function isReasonableSize() {
      return request.resource.data.keys().size() < 100; // Max 100 fields
    }
    
    // ==================== Users Collection ====================
    // פרופילי משתמשים - מידע רגיש!
    match /users/{userId} {
      // קריאה: הבעלים רואה הכל, מנהל רואה הכל
      // משתמשים אחרים יכולים לקרוא רק שדות ציבוריים
      // NOTE: Firestore rules לא תומך בהגבלה ברמת שדה.
      // לפיצול אמיתי — יש ליצור subcollection "users/{userId}/private"
      // ולהעביר לשם מידע רגיש (email, settings).
      // בינתיים — מותר read רק למחוברים (לא public).
      allow read: if isOwner(userId) || isAdmin() || isAuthenticated();
      
      // יצירה: רק המשתמש עצמו יכול ליצור את הפרופיל שלו
      // פשוט - רק בדיקה שזה הבעלים ושלא מנסה להיות admin
      allow create: if isOwner(userId) &&
        (!('isAdmin' in request.resource.data) || request.resource.data.isAdmin == false);
      
      // עדכון: המשתמש יכול לעדכן את עצמו (בלי לשנות isAdmin), מנהל יכול לעדכן הכל
      // מעקב: משתמשים מחוברים יכולים לעדכן רק את שדה followers (להוסיף/להסיר את עצמם)
      allow update: if 
        // משתמש רגיל - יכול לעדכן רק את הפרופיל שלו
        (isOwner(userId) && 
         (!('isAdmin' in request.resource.data) || 
          !('isAdmin' in resource.data) || 
          request.resource.data.isAdmin == resource.data.isAdmin)) ||
        // מנהל יכול לעדכן הכל
        isAdmin() ||
        // משתמשים מחוברים יכולים לעדכן רק את שדה followers
        // ובתנאי שהם מוסיפים/מסירים רק את עצמם (לא של אחרים)
        (isAuthenticated() && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers']) &&
         // Verify: the only change is adding or removing the caller's own uid
         (request.resource.data.followers.hasAll([request.auth.uid]) || 
          resource.data.followers.hasAll([request.auth.uid])));
      
      // מחיקה: רק מנהל יכול למחוק משתמש
      allow delete: if isAdmin();
      
      // Notifications subcollection - התראות למשתמש
      match /notifications/{notificationId} {
        // משתמש יכול לקרוא את ההתראות שלו
        allow read: if isOwner(userId) || isAdmin();
        // משתמשים מחוברים יכולים ליצור התראות
        // בדיקה: חייב להגיע עם שדות מינימליים ולא לזייף את השולח
        allow create: if isAuthenticated() && 
          request.resource.data.keys().hasAll(['type', 'createdAt']) &&
          request.resource.data.keys().size() < 15;
        // רק בעל ההתראה או מנהל יכולים לעדכן/למחוק
        allow update, delete: if isOwner(userId) || isAdmin();
      }

      // Blocked Users subcollection - חסימת משתמשים
      match /blockedUsers/{blockedId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, delete: if isOwner(userId);
      }
    }

    // ==================== Routes Collection ====================
    // מסלולי טיפוס - מידע ציבורי
    match /routes/{routeId} {
      // כולם יכולים לקרוא מסלולים
      allow read: if true;
      
      // רק משתמשים מחוברים יכולים ליצור מסלולים עם ה-userId שלהם
      allow create: if isAuthenticated() && isReasonableSize() &&
        request.resource.data.createdBy == request.auth.uid;
      
      // עדכון מסלולים:
      // - יוצר המסלול או מנהל יכולים לעדכן הכל
      // - משתמשים מחוברים יכולים לעדכן רק שדות סטטיסטיקה (לאחר שליחת פידבק)
      // TODO: להעביר עדכון סטטיסטיקה ל-Cloud Function triggered on feedback write
      //       כדי למנוע מניפולציה ידנית של ערכים
      allow update: if isAdmin() || 
         (isAuthenticated() && resource.data.createdBy == request.auth.uid &&
          // מניעת שינוי createdBy
          request.resource.data.createdBy == resource.data.createdBy) ||
         // Allow any authenticated user to update stats fields only
         (isAuthenticated() && 
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['averageStarRating', 'calculatedGrade', 'feedbackCount', 'completionCount', 'rating', 'tops', 'comments', 'gradeDistribution', 'updatedAt']));
      
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.createdBy == request.auth.uid);
      
      // Legacy feedbacks subcollection
      // פידבקים ישנים בתוך מסלולים (subcollection)
      match /feedbacks/{feedbackId} {
        // כולם יכולים לקרוא פידבקים
        allow read: if true;
        
        // רק משתמשים מחוברים יכולים ליצור פידבק
        allow create: if isAuthenticated() && isReasonableSize() &&
          request.resource.data.userId == request.auth.uid;
        
        // רק היוצר או מנהל יכולים לעדכן/למחוק
        allow update: if isReasonableSize() && 
          (isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid));
        allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      }
    }

    // ==================== Wall Tapes Collection ====================
    // טייפים של הקיר - ניהול על ידי מנהלים
    match /wallTapes/{tapeId} {
      // כולם יכולים לקרוא טייפים
      allow read: if true;
      
      // רק מנהלים יכולים ליצור, לעדכן ולמחוק טייפים
      allow create: if isAdmin() && isReasonableSize();
      allow update: if isAdmin() && isReasonableSize();
      allow delete: if isAdmin();
    }

    // ==================== Route Feedbacks Collection ====================
    // פידבקים על מסלולים
    match /routeFeedbacks/{feedbackId} {
      // כולם יכולים לקרוא פידבקים
      allow read: if true;
      
      // רק משתמשים מחוברים יכולים ליצור פידבק עם ה-userId שלהם
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      
      // רק היוצר או מנהל יכולים לעדכן/למחוק
      allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // ==================== User Route Status Collection ====================
    // סטטוס מסלולים אישי לכל משתמש
    match /userRouteStatus/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
    }
    
    // ==================== Community Routes ====================
    // מסלולי קהילה - מסלולים על תמונות אמיתיות
    match /communityRoutes/{routeId} {
      allow read: if true;
      // יצירה: משתמשים מחוברים יכולים ליצור מסלולים עם ה-userId שלהם
      allow create: if isAuthenticated() && 
        request.resource.data.createdBy == request.auth.uid;
      // עדכון: היוצר או מנהל יכולים לעדכן הכל
      // משתמשים מחוברים יכולים לעדכן רק שדות סטטיסטיקה (צפיות, לייקים, תגובות, משוב)
      allow update: if 
        // מנהל יכול לעדכן הכל
        isAdmin() || 
        // היוצר יכול לעדכן הכל
        (isAuthenticated() && resource.data.createdBy == request.auth.uid) ||
        // משתמשים מחוברים יכולים לעדכן רק שדות סטטיסטיקה
        (isAuthenticated() && 
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['viewCount', 'likeCount', 'commentCount', 'sentCount', 'feedbackCount', 'averageStarRating', 'calculatedGrade']));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.createdBy == request.auth.uid);
    }
    
    match /communityRouteComments/{commentId} {
      allow read: if true;
      // משתמשים יכולים ליצור תגובות עם ה-userId שלהם
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      // משתמשים יכולים לעדכן רק את התגובות שלהם
      allow update: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      // מחיקה: בעל התגובה, מנהל, או יוצר המסלול
      allow delete: if isAdmin() || 
        (isAuthenticated() && resource.data.userId == request.auth.uid) ||
        (isAuthenticated() && 
         exists(/databases/$(database)/documents/communityRoutes/$(resource.data.routeId)) &&
         get(/databases/$(database)/documents/communityRoutes/$(resource.data.routeId)).data.createdBy == request.auth.uid);
    }
    
    match /communityRouteLikes/{likeId} {
      allow read: if true;
      // משתמש יכול ליצור לייק רק עם ה-userId שלו
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      // מחיקה: בעל הלייק, מנהל, או יוצר המסלול
      allow delete: if isAdmin() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid) ||
        (isAuthenticated() && 
         exists(/databases/$(database)/documents/communityRoutes/$(resource.data.routeId)) &&
         get(/databases/$(database)/documents/communityRoutes/$(resource.data.routeId)).data.createdBy == request.auth.uid);
    }

    // משוב על מסלולי קהילה (דירוג כוכבים ודרגה מוצעת)
    match /communityRouteFeedback/{feedbackId} {
      allow read: if true;
      // משתמשים יכולים ליצור משוב עם ה-userId שלהם
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      // משתמשים יכולים לעדכן רק את המשוב שלהם
      allow update: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      // מחיקה: בעל המשוב, מנהל, או יוצר המסלול
      allow delete: if isAdmin() || 
        (isAuthenticated() && resource.data.userId == request.auth.uid) ||
        (isAuthenticated() && 
         exists(/databases/$(database)/documents/communityRoutes/$(resource.data.routeId)) &&
         get(/databases/$(database)/documents/communityRoutes/$(resource.data.routeId)).data.createdBy == request.auth.uid);
    }

    // ==================== Spray Wall Collections ====================
    // קירות ספריי
    match /walls/{wallId} {
      // כולם יכולים לקרוא את הקירות
      allow read: if true;
      
      // רק מנהלים יכולים ליצור/לעדכן/למחוק קירות
      allow create: if isAdmin() && isReasonableSize();
      allow update: if isAdmin() && isReasonableSize();
      allow delete: if isAdmin();
    }
    
    // מסלולי ספריי וואל
    match /sprayRoutes/{routeId} {
      // כולם יכולים לקרוא מסלולים
      allow read: if true;
      
      // משתמשים מחוברים יכולים ליצור מסלולים עם ה-userId שלהם
      allow create: if isAuthenticated() && isReasonableSize() &&
        request.resource.data.createdBy == request.auth.uid;
      
      // עדכון מסלולים:
      // - היוצר או מנהל יכולים לעדכן הכל
      // - משתמשים מחוברים יכולים לעדכן רק שדות סטטיסטיקה (לאחר שליחת פידבק)
      allow update: if isAdmin() || 
         (isAuthenticated() && resource.data.createdBy == request.auth.uid) ||
         // Allow any authenticated user to update stats fields only
         (isAuthenticated() && 
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['averageStarRating', 'calculatedGrade', 'feedbackCount', 'topsCount', 'communityGrade', 'updatedAt']));
      
      // מחיקה - היוצר או מנהל
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.createdBy == request.auth.uid);
      
      // Feedbacks subcollection for spray routes
      // פידבקים בתוך מסלולי ספריי (subcollection)
      match /feedbacks/{feedbackId} {
        // כולם יכולים לקרוא פידבקים
        allow read: if true;
        
        // רק משתמשים מחוברים יכולים ליצור פידבק
        // Temporarily removed isReasonableSize() for debugging
        allow create: if isAuthenticated() &&
          request.resource.data.userId == request.auth.uid;
        
        // רק היוצר או מנהל יכולים לעדכן/למחוק
        allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
        allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      }
    }
    
    // פידבקים על מסלולי ספריי וואל
    match /sprayRouteFeedbacks/{feedbackId} {
      allow read: if true;
      allow create: if isAuthenticated() && isReasonableSize() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isReasonableSize() && 
        (isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
    
    // מסלולי ספריי שהמשתמש סגר (לסינון לפי סטטוס השלמה)
    match /sprayRouteSends/{sendId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
        (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ==================== Social - Follows ====================
    // מעקב בין משתמשים
    match /follows/{followId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
        request.resource.data.followerId == request.auth.uid;
      allow delete: if isAuthenticated() && 
        resource.data.followerId == request.auth.uid;
    }

    // ==================== Competitions Collection ====================
    // מערכת תחרויות - ליגה ארצית וטוטמטישן
    match /competitions/{competitionId} {
      // Anyone can read competition details
      allow read: if true;
      
      // Only admins can create/update/delete competitions
      allow create: if isAdmin() && isReasonableSize();
      allow update: if isAdmin() && isReasonableSize();
      allow delete: if isAdmin();
      
      // Routes Sub-collection
      match /routes/{routeId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();
      }
      
      // Participants Sub-collection
      match /participants/{participantId} {
        allow read: if true;
        // Allow create if:
        // 1. Admin or judge with canAddParticipants permission
        // 2. Self-registration: authenticated user registering themselves when registration is open
        allow create: if isAdmin() || 
          canJudgeAddParticipants(competitionId) ||
          (isAuthenticated() && 
           get(/databases/$(database)/documents/competitions/$(competitionId)).data.registrationStatus == 'open' &&
           request.resource.data.userId == request.auth.uid);
        allow update: if isAdmin() || 
          (isJudge(competitionId) && 
           getJudgePermissions(competitionId).canEditParticipants == true) ||
          // Allow user to cancel their own registration
          (isAuthenticated() && resource.data.userId == request.auth.uid && 
           request.resource.data.status == 'cancelled');
        allow delete: if isAdmin();
      }
      
      // Results Sub-collection
      match /results/{participantId} {
        allow read: if true;
        allow create: if isCompetitionActive(competitionId) && validCompetitionResult() &&
          (isAdmin() || canJudgeEnterResults(competitionId) ||
           // Self-entry: participant can create their own results (points_competition / totemtition)
           (isAuthenticated() && request.auth.uid == participantId));
        allow update: if validCompetitionResult() && ((isCompetitionActive(competitionId) && 
          (isAdmin() || canJudgeEditResults(competitionId) ||
           // Self-entry: participant can update their own results (points_competition / totemtition)
           (isAuthenticated() && request.auth.uid == participantId))) ||
          isAdmin());
        allow delete: if isAdmin();

        // Append-only edit history for audit / conflict review.
        // Written inside the same transaction that mutates the result, so
        // anyone allowed to write the parent can write history. History
        // entries are immutable once created.
        match /history/{historyId} {
          allow read: if true;
          allow create: if isCompetitionActive(competitionId) &&
            (isAdmin() || canJudgeEnterResults(competitionId) || canJudgeEditResults(competitionId) ||
             (isAuthenticated() && request.auth.uid == participantId));
          allow update, delete: if false;
        }
      }
      
      // Judges Sub-collection
      match /judges/{judgeId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();
      }
      
      // Categories Sub-collection
      match /categories/{categoryId} {
        allow read: if true;
        allow create, update, delete: if isAdmin() ||
          (isJudge(competitionId) && 
           getJudgePermissions(competitionId).canManageCategories == true);
      }
    }
    
    // Competition Leaderboards (Denormalized)
    match /competition_leaderboards/{competitionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==================== Ratings Collection ====================
    // דירוגי מסלולים
    match /ratings/{ratingId} {
      // כולם יכולים לקרוא דירוגים
      allow read: if true;
      
      // רק משתמשים מחוברים יכולים ליצור דירוג עם ה-userId שלהם
      allow create: if isAuthenticated() && isReasonableSize() &&
        request.resource.data.userId == request.auth.uid;
      
      // רק היוצר או מנהל יכולים לעדכן/למחוק
      allow update: if isReasonableSize() && 
        (isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // ==================== Feedback Collection ====================
    // פידבקים (top-level collection - legacy)
    match /feedback/{feedbackId} {
      // כולם יכולים לקרוא פידבקים
      allow read: if true;
      
      // רק משתמשים מחוברים יכולים ליצור פידבק עם ה-userId שלהם
      allow create: if isAuthenticated() && isReasonableSize() &&
        request.resource.data.userId == request.auth.uid;
      
      // רק היוצר או מנהל יכולים לעדכן/למחוק
      allow update: if isReasonableSize() && 
        (isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // ==================== Push Tokens ====================
    // טוקנים להתראות Push - כל משתמש שומר רק את שלו
    match /userPushTokens/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    // ==================== Error Reports ====================
    // דיווחי שגיאות - משתמשים יכולים לכתוב, רק מנהלים קוראים
    match /errorReports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isReasonableSize();
      allow update, delete: if isAdmin();
    }

    // ==================== Content Reports ====================
    // דיווחים על תוכן ומשתמשים - UGC מודרציה
    match /contentReports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isReasonableSize();
      allow update, delete: if isAdmin();
    }

    // ==================== Blocked Users ====================
    // חסימת משתמשים - כל משתמש מנהל את רשימת החסומים שלו
    // Note: stored as subcollection under users/{userId}/blockedUsers/{blockedId}
    // Rules already covered by users collection match with subcollection write

    // ==================== App Settings ====================
    // הגדרות אפליקציה (default avatar, etc.)
    match /settings/{settingId} {
      // כולם יכולים לקרוא הגדרות
      allow read: if true;
      // רק מנהלים יכולים לשנות הגדרות
      allow write: if isAdmin();
    }

    // ==================== Announcements ====================
    // הודעות מערכת
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==================== Color Settings ====================
    // הגדרות צבעים מותאמות אישית
    match /colorSettings/{colorId} {
      // כולם יכולים לקרוא הגדרות צבעים
      allow read: if true;
      // רק מנהלים יכולים לשנות הגדרות צבעים
      allow write: if isAdmin();
    }

    // ==================== App Settings ====================
    // הגדרות אפליקציה כלליות (צבעים מוסתרים וכו')
    match /appSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==================== Community Route Sends ====================
    // שליחות/סגירות מסלולי קהילה
    match /communityRouteSends/{sendId} {
      allow read: if true;
      // משתמשים יכולים ליצור רק עם ה-userId שלהם
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      // משתמשים יכולים לעדכן רק את שלהם
      allow update: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      // מחיקה: בעל השליחה, מנהל, או יוצר המסלול
      allow delete: if isAdmin() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid) ||
        (isAuthenticated() && 
         exists(/databases/$(database)/documents/communityRoutes/$(resource.data.routeId)) &&
         get(/databases/$(database)/documents/communityRoutes/$(resource.data.routeId)).data.createdBy == request.auth.uid);
    }

    // ==================== User Routes ====================
    // מסלולי משתמש - document ID is the userId
    match /userRoutes/{userId} {
      // משתמש יכול לקרוא רק את הנתונים שלו, מנהל יכול לקרוא הכל
      allow read: if isOwner(userId) || isAdmin();
      // משתמש יכול ליצור/לעדכן רק את המסמך שלו, מנהל יכול לעדכן הכל (לסנכרון)
      allow create, update: if (isOwner(userId) && isReasonableSize()) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ==================== Editor Rooms ====================
    // חדרי עריכה - לעורך הקירות
    match /editor_rooms/{roomId} {
      // קריאה: 
      // 1. חדרים מפורסמים - קריאה ציבורית (נדרש למסך הטלוויזיה ללא התחברות)
      // 2. חדרים של המשתמש עצמו - תמיד יכול לקרוא
      // 3. מנהל - יכול לקרוא הכל
      allow read: if isAuthenticated() || resource.data.isPublished == true;
      
      // משתמש מחובר יכול ליצור חדר (עם ה-userId שלו)
      allow create: if isAuthenticated() && 
        request.resource.data.createdBy == request.auth.uid &&
        isReasonableSize();
      
      // משתמש יכול לעדכן רק את החדרים שהוא יצר, או מנהל
      allow update: if isAuthenticated() && 
        (resource.data.createdBy == request.auth.uid || isAdmin()) &&
        isReasonableSize();
      
      // משתמש יכול למחוק רק את החדרים שהוא יצר, או מנהל
      allow delete: if isAuthenticated() && 
        (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // ==================== Shift Management ====================
    // ניהול משמרות - מערכת שיבוץ עובדים

    // תפקידי משמרת - ניהול על ידי מנהלים
    match /shiftRoles/{roleId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isReasonableSize();
      allow update: if isAdmin() && isReasonableSize();
      allow delete: if isAdmin();
    }

    // שיוך עובדים לתפקידי משמרת - ניהול על ידי מנהלים
    match /userShiftRoles/{userId} {
      // כל משתמש מחובר יכול לקרוא (כדי לבדוק אם הוא עובד)
      allow read: if isAuthenticated();
      // רק מנהלים יכולים לשנות שיוך תפקידים
      allow write: if isAdmin();
    }

    // משמרות
    // משמרות
    match /shifts/{shiftId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isReasonableSize();
      // מנהלים יכולים לעדכן הכל, מנהלי משמרות יכולים לעדכן assignedWorkerIds, עובדים יכולים רק להסיר את עצמם
      allow update: if isReasonableSize() && (
        isAdmin() ||
        isShiftManager() ||
        (isAuthenticated() &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['assignedWorkerIds', 'updatedAt']) &&
         !(request.auth.uid in request.resource.data.assignedWorkerIds) &&
         request.auth.uid in resource.data.assignedWorkerIds)
      );
      allow delete: if isAdmin();
    }

    // הרשמות למשמרות
    match /shiftRegistrations/{registrationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isReasonableSize() &&
        request.resource.data.userId == request.auth.uid;
      // מנהלים ומנהלי משמרות יכולים לעדכן הרשמות
      // עובדים יכולים לבטל רק הרשמות שטרם אושרו (pending)
      // מערכת ההחלפה (swap_system) מטופלת דרך batch writes עם הרשמות חדשות
      allow update: if isAdmin() || isShiftManager() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid &&
         resource.data.status == 'pending' &&
         request.resource.data.status == 'cancelled');
      allow delete: if isAdmin();
    }

    // בקשות החלפת משמרות
    match /shiftSwapRequests/{requestId} {
      allow read: if isAuthenticated();
      // יצירה: רק המבקש יכול ליצור בקשת החלפה
      allow create: if isAuthenticated() && isReasonableSize() &&
        request.resource.data.requesterId == request.auth.uid;
      // עדכון: המשתמש המבוקש, מנהלים או מנהלי משמרות יכולים לעדכן
      allow update: if isAdmin() || isShiftManager() ||
        (isAuthenticated() && resource.data.targetUserId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // היסטוריית משמרות
    match /shiftHistory/{historyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isReasonableSize();
      allow update, delete: if isAdmin();
    }

    // ==================== Staff Tasks & Q&A (employees only) ====================
    // גידור לצוות בלבד: רק עובד/מנהל-משמרת/אדמין רואה. לא חשוף למטפסים רגילים.

    // קבוצות משימות (צ׳קליסט לתפקיד) — ניהול על ידי מנהלי משמרת/אדמין
    match /taskLists/{listId} {
      allow read: if isWorker() || isShiftManager() || isAdmin();
      allow create, update: if (isShiftManager() || isAdmin()) && isReasonableSize();
      allow delete: if isShiftManager() || isAdmin();
    }

    // משימות אישיות לעובד למשמרת
    match /shiftTasks/{taskId} {
      allow read: if isWorker() || isShiftManager() || isAdmin();
      // יצירה/מחיקה — מנהל משמרת/אדמין (הלקוח יוצר אותן בעת אישור עובד)
      allow create: if (isShiftManager() || isAdmin()) && isReasonableSize();
      allow delete: if isShiftManager() || isAdmin();
      // עדכון: מנהל/אדמין הכל; העובד מעדכן רק done/doneAt במשימה של עצמו
      allow update: if (isShiftManager() || isAdmin()) ||
        (isAuthenticated() && resource.data.uid == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['done', 'doneAt']));
    }

    // שאלות ותשובות (מאגר ידע לצוות)
    match /questions/{questionId} {
      // מנהל/אדמין רואה הכל; עובד רואה שאלות גלויות שנענו + השאלות של עצמו.
      // מטפס רגיל (לא עובד) — חסום לגמרי, כולל מהמאגר.
      allow read: if isShiftManager() || isAdmin() ||
        (isWorker() && resource.data.visible == true && resource.data.status == 'answered') ||
        (isWorker() && resource.data.authorUid == request.auth.uid);
      // עובד יוצר שאלה על שמו בסטטוס open; מנהל/אדמין יוצר רשומת מאגר ישירות
      allow create: if (isWorker() && isReasonableSize() &&
          request.resource.data.authorUid == request.auth.uid &&
          request.resource.data.status == 'open') ||
        ((isShiftManager() || isAdmin()) && isReasonableSize());
      // מענה/עריכה/הסתרה/מחיקה — מנהל משמרת/אדמין בלבד
      allow update, delete: if isShiftManager() || isAdmin();
    }

    // תיקיות מאגר הידע (קיבוץ שאלות) — קריאה לצוות, כתיבה למנהל/אדמין
    match /qaFolders/{folderId} {
      allow read: if isWorker() || isShiftManager() || isAdmin();
      allow create, update, delete: if (isShiftManager() || isAdmin()) && isReasonableSize();
    }

    // ==================== Class Planning ====================
    // הגדרות גלובליות לתכנון חוגים — מסמך יחיד "global"
    match /classSettings/{settingsId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isReasonableSize();
    }

    // מיקומים פיזיים (קירות, כר ילדים, אזורי אימון)
    match /classLocations/{locationId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isReasonableSize();
      allow update: if isAdmin() && isReasonableSize();
      allow delete: if isAdmin();
    }

    // מסלולי תשלום (Programs)
    match /classPrograms/{programId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isReasonableSize();
      allow update: if isAdmin() && isReasonableSize();
      allow delete: if isAdmin();
    }

    // קבוצות כלכליות (Groups) — יחידת ההכנסה
    match /classGroups/{groupId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isReasonableSize();
      allow update: if isAdmin() && isReasonableSize();
      allow delete: if isAdmin();
    }

    // אימונים בלוח (Sessions) — שיבוץ של קבוצה
    match /classSessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isReasonableSize();
      allow update: if isAdmin() && isReasonableSize();
      allow delete: if isAdmin();
    }

    // ==================== Default Deny ====================
    // כל מה שלא מוגדר במפורש - אסור!
    // זה חשוב לאבטחה - אין גישה לכלום שלא מוגדר
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

